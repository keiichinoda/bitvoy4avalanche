{
  "name": "bitvoy-oidc-provider",
  "version": "1.0.0",
  "description": "BitVoy OIDC認証プロバイダー - BitVoy側でOIDC認証を提供するための実装",
  "main": "bitvoy-oidc-provider.js",
  "scripts": {
    "start": "node bitvoy-oidc-provider.js",
    "dev": "nodemon bitvoy-oidc-provider.js",
    "create-client": "node create-oidc-client.js",
    "setup-db": "mysql -u root -p bitvoy < bitvoy_oidc_provider_schema.sql",
    "test": "jest",
    "lint": "eslint ."
  },
  "keywords": [
    "oidc",
    "openid-connect",
    "authentication",
    "bitvoy",
    "provider"
  ],
  "author": "BitVoy Team",
  "license": "MIT",
  "dependencies": {
    "@simplewebauthn/server": "^8.3.6",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "crypto": "^1.0.1",
    "dotenv": "^16.3.1",
    "ethers": "^5.7.2",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "express-session": "^1.17.3",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.6.5",
    "readline": "^1.3.0",
    "ulid": "^2.3.0"
  },
  "devDependencies": {
    "eslint": "^8.55.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bitvoy/bitvoy-oidc-provider.git"
  },
  "bugs": {
    "url": "https://github.com/bitvoy/bitvoy-oidc-provider/issues"
  },
  "homepage": "https://github.com/bitvoy/bitvoy-oidc-provider#readme"
